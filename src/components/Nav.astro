---
const links = [
  { label: 'About', href: '/#about' },
  { label: 'Work', href: '/#work' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/#hero" class="brand">
      <span>Manu</span>
      <span class="accent">Barranco</span>
    </a>
    <nav class="links" aria-label="Primary">
      {links.map((l, i) => (
        <>
          {i > 0 && <span class="sep" aria-hidden="true">·</span>}
          <a href={l.href}>{l.label}</a>
        </>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav { border-bottom: 1.5px solid var(--color-core-border-strong); position: sticky; top: 0; z-index: 100; background: var(--color-core-background-default); overflow: hidden; }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 22px var(--space-gutter);
    will-change: transform;
  }
  .brand {
    display: flex;
    flex-direction: column;
    font-family: var(--font-family-headline);
    font-weight: 400;
    font-size: clamp(28px, 3.4vw, 40px);
    line-height: 0.82;
    letter-spacing: -0.01em;
  }
  .brand .accent { color: var(--color-accent-default); }
  .links {
    display: flex;
    align-items: baseline;
    gap: 14px;
    font-family: var(--font-family-headline);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .links a { transition: color 0.12s, background 0.12s, box-shadow 0.12s; }
  .links a:hover { background: var(--color-accent-default); color: var(--color-core-background-default); box-shadow: 0 0 0 0.1em var(--color-accent-default); }
  .links .sep { color: var(--color-core-foreground-subtle); }
  @media (max-width: 560px) {
    .links { gap: 10px; }
  }
</style>
