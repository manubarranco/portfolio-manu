---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <script is:inline>
    /* Hide the morphing brand + links until JS positions them (avoids a small-logo flash) */
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('morph-js');
    }
  </script>

  <Nav />

  <main>
    <!-- ═══ COVER — landing masthead; scrolls up under the header as it reveals ═══ -->
    <section class="cover">
      <div class="wrap cover-inner">
        <div class="cover-name" aria-hidden="true">
          <span>Manu</span>
          <span class="accent">Barranco</span>
        </div>
        <div class="cover-foot">
          <div class="cover-rule" aria-hidden="true"></div>
          <p class="cover-tagline">Senior Design Systems Lead · AI Native Product Design</p>
        </div>
      </div>
    </section>

    <!-- ═══ HERO — frame; stays in main theme throughout ═══ -->
    <section id="hero" class="hero wrap" aria-labelledby="hero-title">
      <div class="idx mono">00</div>
      <div class="hero-col">
        <p class="status mono"><span class="dot" aria-hidden="true"></span> Available for new challenges</p>

        <h1 id="hero-title" class="hero-h">I turn product complexity into <span id="rot" class="hl rot-phrase">systems that actually get adopted</span></h1>

        <div class="lede">
          <p class="pos">
            I define the system and make the decisions that set the direction.
            Then I lead the execution and adoption to make it real.
          </p>
          <p class="through">
            I'm not discovering AI now. It's the latest in a series of waves I've been part of
            from the start: the web, UX, design systems, behavioral design.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ ACTO 0 — who I am / how I work ═══ -->
    <section class="acto-0" aria-labelledby="acto-label">
      <div class="wrap acto-grid">
        <div class="idx mono" aria-hidden="true">·</div>
        <div class="acto-body">
          <p id="acto-label" class="eyebrow">Who I am · How I work</p>

          <ol class="beats" role="list">

            <!-- 1 · Altitud -->
            <li class="beat" data-reveal>
              <span class="beat-n mono" aria-hidden="true">01</span>
              <p class="beat-text beat-text--lg">
                Most designers hand off. I define the system, make the decisions
                that set direction, lead the execution, and stay until
                it's adopted.
              </p>
            </li>

            <!-- 2 · Cómo pienso -->
            <li class="beat" data-reveal>
              <span class="beat-n mono" aria-hidden="true">02</span>
              <p class="beat-text">
                I look for the invariants first: what must be true regardless of
                implementation. Structure before system. System before screens.
              </p>
            </li>

            <!-- 3 · El puente -->
            <li class="beat" data-reveal>
              <span class="beat-n mono" aria-hidden="true">03</span>
              <p class="beat-text">
                I speak product fluently enough to push back on direction.
                Engineering fluently enough to know what's real.
                That's not a soft skill. It's how systems actually get built.
              </p>
            </li>

            <!-- 4 · Autoridad tranquila -->
            <li class="beat" data-reveal>
              <span class="beat-n mono" aria-hidden="true">04</span>
              <p class="beat-text">
                I've led design at global scale and built an AI-native product
                from zero. I don't need to be the loudest voice in the room.
                I need to be the most useful one.
              </p>
            </li>

            <!-- 5 · Arquetipo: The Infrastructure Maker -->
            <li class="beat beat--archetype" id="beat-archetype" data-reveal>
              <span class="beat-n mono" aria-hidden="true">05</span>
              <div class="archetype-inner">
                <p class="beat-text archetype-setup">
                  I built a product that reads professional trajectories.
                  I gave it mine. It returned this:
                </p>
                <p class="archetype-label" id="archetype-label">
                  The Infrastructure Maker
                </p>
                <p class="archetype-sub">
                  The one who builds what needs to exist for everything else
                  to work.
                </p>
              </div>
            </li>

            <!-- 6 · Olas semilla -->
            <li class="beat beat--olas" data-reveal>
              <span class="beat-n mono" aria-hidden="true">06</span>
              <div class="olas-inner">
                <p class="beat-text olas-frame">
                  Five waves. I don't discover categories. I arrive when
                  they're forming.
                </p>
                <ol class="olas-list" role="list" aria-label="Industry waves">
                  <li>The web</li>
                  <li>Portals</li>
                  <li>UX</li>
                  <li>Design systems</li>
                  <li class="ola-current">AI</li>
                </ol>
              </div>
            </li>

          </ol>
        </div>
      </div>
    </section>

    <!-- ═══ CONTENT AREA — morphs through universe themes ═══ -->
    <div id="content-area">

      <!-- ── Universe 01 · Ruralvía ───────────────────────────────── -->
      <div class="uni-trigger" id="rv-trigger" aria-hidden="true"></div>

      <section class="uni-showcase wrap" data-universe="ruralvia" aria-labelledby="rv-title">
        <div class="uni-header" data-reveal>
          <p class="eyebrow">01 · Ruralvía · 2018–2019 · Caja Rural</p>
          <h2 id="rv-title" class="uni-tagline">An expert<br>in your corner</h2>
        </div>
        <div class="uni-cards">
          <div class="uni-card" data-reveal style="transition-delay:60ms">
            <p class="uni-card-label eyebrow">Vision</p>
            <p class="uni-card-body">Before Cleo, Revolut, N26. We built proactive financial advice in 2018 around a single insight: users didn't need features, they needed someone in their corner.</p>
          </div>
          <div class="uni-card" data-reveal style="transition-delay:120ms">
            <p class="uni-card-label eyebrow">System</p>
            <p class="uni-card-body">Proto-design system with tokens, flows, and a UI library that scaled across 70+ financial entities within Caja Rural Group.</p>
          </div>
          <div class="uni-card uni-card--cta" data-reveal style="transition-delay:180ms">
            <p class="uni-card-label eyebrow">The differentiator</p>
            <p class="uni-card-body">El Experto, a contextual advisor embedded in the home screen. Not a chatbot. Someone who noticed things before you did.</p>
            <a href="/work/ruralvia" class="uni-link">Read the case study ↗</a>
          </div>
        </div>
      </section>

      <!-- ── Universe 02 · Flame ──────────────────────────────────── -->
      <div class="uni-trigger uni-trigger--short" id="flame-trigger" aria-hidden="true"></div>

      <section class="uni-showcase wrap" data-universe="flame" aria-labelledby="flame-title">
        <div class="uni-header" data-reveal>
          <p class="eyebrow">02 · Flame · 2020–2024 · Santander</p>
          <h2 id="flame-title" class="uni-tagline">A system teams<br>chose to adopt</h2>
        </div>
        <div class="uni-cards">
          <div class="uni-card" data-reveal style="transition-delay:60ms">
            <p class="uni-card-label eyebrow">Scale</p>
            <p class="uni-card-body">1,780+ components governed across 350+ designers and 10 countries. In banking, design coherence isn't a UX nicety: it's a trust signal.</p>
          </div>
          <div class="uni-card" data-reveal style="transition-delay:120ms">
            <p class="uni-card-label eyebrow">The model</p>
            <p class="uni-card-body">A tiered system: a global foundation with local layers. Teams moved fast locally without fragmenting the platform at scale.</p>
          </div>
          <div class="uni-card uni-card--cta" data-reveal style="transition-delay:180ms">
            <p class="uni-card-label eyebrow">Impact</p>
            <p class="uni-card-body">~35% faster feature development. I led the system, the team, and the alignment with Santander's Chief Design Officer.</p>
            <a href="/work/flame" class="uni-link">Read the case study ↗</a>
          </div>
        </div>
      </section>

      <!-- ── Universe 03 · Erneszt (climax) ───────────────────────── -->
      <div class="uni-trigger uni-trigger--short" id="erneszt-trigger" aria-hidden="true"></div>

      <section class="uni-showcase wrap" data-universe="erneszt" aria-labelledby="erneszt-title">
        <div class="uni-header" data-reveal>
          <p class="eyebrow">03 · Erneszt · 2026 · Self-initiated</p>
          <h2 id="erneszt-title" class="uni-tagline">The thesis,<br>made real</h2>
        </div>
        <div class="uni-cards">
          <div class="uni-card" data-reveal style="transition-delay:60ms">
            <p class="uni-card-label eyebrow">Thesis</p>
            <p class="uni-card-body">An AI-native product, built from zero. Conceived, designed, and orchestrated end to end. The arc's climax, made real.</p>
          </div>
          <div class="uni-card" data-reveal style="transition-delay:120ms">
            <p class="uni-card-label eyebrow">Emotional architecture</p>
            <p class="uni-card-body">Designed the emotional architecture before the product: the "this is me" click of a viral test with the depth of a real coach.</p>
          </div>
          <div class="uni-card uni-card--cta" data-reveal style="transition-delay:180ms">
            <p class="uni-card-label eyebrow">The product</p>
            <p class="uni-card-body">Zoltar, an automaton that reads your trajectory and returns it as something you can finally claim. Try it free with HIREMANU.</p>
            <a href="/work/erneszt" class="uni-link">Read the case study ↗</a>
          </div>
        </div>
      </section>

      <!-- About + closing CTA — rests in the Erneszt theme -->
      <section id="about" class="about wrap" aria-labelledby="about-title">
        <div class="idx mono">·</div>
        <div class="about-col" data-reveal>
          <p id="about-title" class="eyebrow">About</p>
          <p class="about-body">
            I'm a systems thinker with a pull toward structure and abstraction. My strength is the
            early definition: shaping the system and making the decisions that set the direction,
            then leading the execution and adoption that make it real. I've led design at scale
            and built an AI-native product from zero.
          </p>
          <div class="end-cta">
            <p class="end-line">Available for new challenges.</p>
            <a href="/contact" class="end-link mono">Get in touch ↗</a>
          </div>
        </div>
      </section>
    </div><!-- /content-area -->
  </main>

  <Footer />
</Base>

<!-- ═══ FLOOD SLATES — fixed overlays, one floods at each transition peak ═══ -->
<div class="slate slate--rv" id="rv-slate" aria-hidden="true">
  <p class="slate-eyebrow">campo y trigo</p>
  <h2 class="slate-title">RURALVÍA</h2>
  <dl class="slate-readout">
    <div class="readout-row"><dt>--paper</dt><dd>#EFEAC6</dd></div>
    <div class="readout-row"><dt>--ink</dt><dd>#1C3A2B</dd></div>
    <div class="readout-row"><dt>--radius</dt><dd>24px</dd></div>
    <div class="readout-row"><dt>--pad</dt><dd>64px</dd></div>
  </dl>
</div>

<div class="slate slate--flame" id="flame-slate" aria-hidden="true">
  <p class="slate-eyebrow">orden y escala</p>
  <h2 class="slate-title">FLAME</h2>
  <dl class="slate-readout">
    <div class="readout-row"><dt>--paper</dt><dd>#ECE9DF</dd></div>
    <div class="readout-row"><dt>--ink</dt><dd>#16160F</dd></div>
    <div class="readout-row"><dt>--radius</dt><dd>0px</dd></div>
    <div class="readout-row"><dt>--pad</dt><dd>64px</dd></div>
  </dl>
</div>

<div class="slate slate--erneszt" id="erneszt-slate" aria-hidden="true">
  <p class="slate-eyebrow">el autómata</p>
  <h2 class="slate-title">ERNESZT</h2>
  <dl class="slate-readout">
    <div class="readout-row"><dt>--paper</dt><dd>#1A1209</dd></div>
    <div class="readout-row"><dt>--ink</dt><dd>#EFEAC6</dd></div>
    <div class="readout-row"><dt>--radius</dt><dd>4px</dd></div>
    <div class="readout-row"><dt>--pad</dt><dd>72px</dd></div>
  </dl>
</div>

<style>
  .idx { color: var(--faint); padding-top: 26px; }

  /* ── cover (landing) — fits the viewport; aligned to the same .wrap grid as the header */
  .cover {
    height: 100svh; /* JS pins this to the visible viewport height */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .cover-inner {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    width: 100%; /* without this, being a flex item with margin:auto sizes it by fit-content
                    instead of stretching to .wrap's max-width — breaks the centering math
                    and misaligns it from the header/hero, which aren't in a flex context */
  }
  .cover-name {
    display: flex;
    flex-direction: column;
    font-family: var(--headline);
    font-weight: 400;
    font-size: clamp(72px, min(20vw, 28vh), 240px);
    line-height: 0.8;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-top: auto;
    margin-bottom: 5vh;
  }
  .cover-name .accent { color: var(--accent); }
  .cover-foot { padding-bottom: 4vh; }
  .cover-rule { height: 1.5px; background: var(--line-strong); width: 100%; margin-bottom: 16px; }
  .cover-tagline {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(17px, 2.6vw, 39px); /* capped so it never outgrows .wrap's maxw and wraps to 2 lines */
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  @media (max-width: 720px) {
    .cover-tagline { line-height: 1.3; }
  }

  /* Anti-flash: keep the header content tucked below the line until the reveal script runs (motion users only) */
  :global(html.morph-js) header.nav .nav-inner { transform: translateY(140%); }

  /* ── hero */
  .hero {
    display: grid;
    grid-template-columns: 80px 1fr;
    border-bottom: 1.5px solid var(--line-strong);
    scroll-margin-top: 124px; /* clearance for the sticky header when jumping to #hero */
  }
  .hero-col { padding: 26px 0 64px; }
  .status { color: var(--accent-ink); text-transform: uppercase; letter-spacing: 0.04em; display: inline-flex; align-items: center; gap: 9px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .hero-h { font-family: var(--display); font-weight: 800; font-size: clamp(34px, 6.8vw, 80px); line-height: 1.0; letter-spacing: -0.02em; max-width: 18ch; margin-top: 44px; }
  .hl { color: var(--accent); }
  .rot-phrase { display: block; text-wrap: balance; min-height: 2em; transition: opacity 0.22s ease; }
  .rot-phrase.is-out { opacity: 0; }
  .lede { margin-top: 44px; display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; max-width: 920px; }
  .pos { font-weight: 500; font-size: 23px; line-height: 1.34; letter-spacing: -0.015em; }
  .through { font-size: 15px; line-height: 1.65; color: var(--muted); }

  /* ── transition trigger zones (invisible; drive the morph) */
  .uni-trigger { height: 200vh; pointer-events: none; }
  .uni-trigger--short { height: 160vh; }

  /* ── flood slates */
  :global(.slate) {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0; /* overridden by JS to match nav height */
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }
  :global(.slate--rv)      { background: rgba(28, 58, 43, 0.97); }
  :global(.slate--flame)   { background: rgba(226, 52, 29, 0.97); }
  :global(.slate--erneszt) { background: rgba(26, 18, 9, 0.97); }

  :global(.slate-eyebrow) {
    font-family: var(--mono);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
  }
  :global(.slate-title) {
    font-weight: 700;
    font-size: clamp(80px, 14vw, 180px);
    line-height: 0.88;
    letter-spacing: -0.01em;
    text-align: center;
  }
  /* Each flood titles itself in its universe's display face */
  :global(.slate--rv .slate-title)      { font-family: 'Fraunces', Georgia, serif;       font-weight: 600; color: #EFEAC6; }
  :global(.slate--flame .slate-title)   { font-family: 'Archivo Black', system-ui, sans-serif; font-weight: 400; color: #F3F1EA; }
  :global(.slate--erneszt .slate-title) { font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-weight: 700; color: #C9A24B; }

  :global(.slate-readout) {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--mono);
    font-size: 12px;
    text-align: left;
    list-style: none;
  }
  :global(.readout-row) { display: flex; gap: 16px; align-items: baseline; }
  :global(.readout-row dt) { color: rgba(255, 255, 255, 0.35); min-width: 80px; }
  :global(.readout-row dd) { color: rgba(255, 255, 255, 0.8); font-weight: 700; min-width: 80px; font-variant-numeric: tabular-nums; }

  /* ── universe showcase (generic; auto-themes from content-area tokens) */
  .uni-showcase {
    padding: 100px var(--pad) 72px; /* must restate --pad: this scoped rule outranks the global .wrap padding,
                                        so leaving it as "0" silently dropped the outer gutter (56px) the header
                                        and hero both use, under-indenting these sections by that amount */
    display: grid;
    grid-template-columns: 80px 1fr;
  }
  .uni-header { grid-column: 2; margin-bottom: 56px; }
  .uni-tagline {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(64px, 10vw, 128px);
    line-height: 0.88;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-top: 20px;
  }
  .uni-cards {
    grid-column: 2;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .uni-card {
    background: var(--paper-2);
    border: var(--bw) solid var(--line);
    border-radius: var(--radius);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .uni-card-label { margin-bottom: 4px; }
  .uni-card-body { font-size: 15px; line-height: 1.6; color: var(--muted); flex: 1; }
  .uni-link {
    display: inline-block;
    margin-top: 20px;
    font-family: var(--mono);
    font-size: 12.5px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
    transition: color 0.12s, background 0.12s, box-shadow 0.12s;
  }
  .uni-link:hover { background: var(--accent); color: var(--paper); box-shadow: 0 0 0 0.1em var(--accent); }

  /* ── about + closing cta */
  .about { display: grid; grid-template-columns: 80px 1fr; border-top: 1.5px solid var(--line); margin-top: 64px; padding-bottom: 96px; }
  .about-col { padding: 26px 0 0; max-width: 680px; }
  .about-col .eyebrow { margin-bottom: 18px; }
  .about-body { font-size: 19px; line-height: 1.55; letter-spacing: -0.01em; }
  .end-cta { margin-top: 40px; display: flex; align-items: baseline; gap: 20px; flex-wrap: wrap; }
  .end-line { font-size: 19px; letter-spacing: -0.01em; color: var(--ink); }
  .end-link {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
    transition: opacity 0.12s;
  }
  .end-link:hover { opacity: 0.65; }

  /* ── acto 0 */
  .acto-0 { border-top: 1.5px solid var(--line-strong); }
  .acto-grid {
    display: grid;
    grid-template-columns: 80px 1fr;
  }
  .acto-body { padding: 26px 0 0; }
  .acto-body > .eyebrow { padding-bottom: 36px; display: block; }

  .beats { list-style: none; border-top: 1.5px solid var(--line); }
  .beat {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 0 24px;
    padding: 36px 0;
    border-bottom: 1.5px solid var(--line);
    align-items: start;
  }
  .beat-n { color: var(--faint); padding-top: 3px; }
  .beat-text { font-size: 17px; line-height: 1.65; letter-spacing: -0.01em; }
  .beat-text--lg {
    font-size: 21px;
    line-height: 1.4;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  /* beat 5 — archetype */
  .beat--archetype { align-items: start; }
  .archetype-inner { display: flex; flex-direction: column; gap: 0; }
  .archetype-setup { color: var(--muted); margin-bottom: 20px; }
  .archetype-label {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(28px, 4.5vw, 52px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--ink);
    transition: color 0.45s ease;
  }
  .archetype-label.is-gold { color: #A87C2A; }
  .archetype-sub {
    font-size: 14px;
    line-height: 1.55;
    color: var(--faint);
    margin-top: 12px;
    max-width: 46ch;
  }

  /* beat 6 — olas */
  .olas-frame { color: var(--muted); margin-bottom: 20px; }
  .olas-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 0;
    font-family: var(--mono);
    font-size: 12.5px;
    letter-spacing: 0.02em;
  }
  .olas-list li { display: flex; align-items: center; }
  .olas-list li:not(:last-child)::after {
    content: '→';
    color: var(--accent);
    margin: 0 10px;
  }
  .ola-current { color: var(--accent); font-weight: 700; }

  @media (max-width: 720px) {
    .hero, .about { grid-template-columns: 1fr; }
    .idx { display: none; }
    .lede { grid-template-columns: 1fr; gap: 24px; }
    .uni-showcase { grid-template-columns: 1fr; }
    .uni-header, .uni-cards { grid-column: 1; }
    .uni-cards { grid-template-columns: 1fr; }
    .uni-trigger { height: 140vh; }
    .uni-trigger--short { height: 120vh; }
    .acto-grid { grid-template-columns: 1fr; }
    .acto-grid > .idx { display: none; }
    .beat { grid-template-columns: 36px 1fr; gap: 0 16px; }
    .beat-text--lg { font-size: 18px; }
    .olas-list { font-size: 11.5px; }
  }
</style>

<script>
  /* ── rotating phrases */
  const phrases = [
    'systems that actually get adopted',
    'decisions that set direction',
    'products ready for AI',
    'systems built to scale',
  ];
  const rotEl = document.getElementById('rot');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (rotEl && !reduce) {
    let i = 0;
    setInterval(() => {
      rotEl.classList.add('is-out');
      setTimeout(() => {
        i = (i + 1) % phrases.length;
        rotEl.textContent = phrases[i];
        rotEl.classList.remove('is-out');
      }, 240);
    }, 3400);
  }

  /* ── reveal on scroll */
  const revealEls = document.querySelectorAll('[data-reveal]');
  if (revealEls.length && !reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      },
      { rootMargin: '0px 0px -12% 0px' },
    );
    revealEls.forEach((n) => io.observe(n));
  } else {
    revealEls.forEach((n) => n.classList.add('in'));
  }

  /* ── beat 5: archetype gold flash */
  const archetypeBeat  = document.getElementById('beat-archetype');
  const archetypeLabel = document.getElementById('archetype-label');

  if (archetypeBeat && archetypeLabel && !reduce) {
    let fired = false;
    const archetypeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !fired) {
            fired = true;
            archetypeLabel.style.fontFamily = "'Playfair Display', Georgia, serif";
            archetypeLabel.style.fontStyle  = 'italic';
            archetypeLabel.classList.add('is-gold');
            setTimeout(() => { archetypeLabel.classList.remove('is-gold'); }, 1300);
            setTimeout(() => {
              archetypeLabel.style.fontFamily = '';
              archetypeLabel.style.fontStyle  = '';
            }, 1750);
            archetypeObs.disconnect();
          }
        });
      },
      { threshold: 0.7 },
    );
    archetypeObs.observe(archetypeBeat);
  }

  /* ── cover → header reveal: the cover scrolls up under the fixed header bar;
     the header content rises from the line as the name disappears (same proportion) ── */
  const navInner  = document.querySelector('header.nav .nav-inner');
  const coverEl   = document.querySelector('.cover');
  const coverName = document.querySelector('.cover-name');
  const coverFoot = document.querySelector('.cover-foot');

  if (navInner && coverEl && coverName && coverFoot && !reduce) {
    let barH = 0, revealStart = 0, revealSpan = 1;
    function measureReveal() {
      barH = document.querySelector('header.nav').offsetHeight;
      coverEl.style.height = (window.innerHeight - barH) + 'px'; /* fill the viewport minus the sticky header so name + role always fit */
      const y = window.scrollY;
      const nameTop = coverName.getBoundingClientRect().top + y;
      const nameBot = coverName.getBoundingClientRect().bottom + y;
      const leadIn  = (nameBot - nameTop) * 0.55; /* start before the name visually touches the line, so the header isn't slow to appear */
      revealStart = (nameTop - barH) - leadIn;
      revealSpan  = Math.max(1, (nameBot - barH) - revealStart); /* completes once "Barranco" has passed the line — well before the #hero anchor lands, so clicking the brand leaves no residual header motion */
    }
    function reveal() {
      let p = (window.scrollY - revealStart) / revealSpan;
      p = Math.max(0, Math.min(1, p));
      /* header content tucked below the line at p=0, risen into place in the same proportion the cover disappears */
      navInner.style.transform = `translateY(${((1 - p) * barH).toFixed(1)}px)`;
    }
    measureReveal();
    reveal();
    document.documentElement.classList.remove('morph-js');
    window.addEventListener('scroll', reveal, { passive: true });
    window.addEventListener('resize', () => { measureReveal(); reveal(); }, { passive: true });
  } else if (reduce) {
    if (coverEl) coverEl.style.display = 'none';
    document.documentElement.classList.remove('morph-js');
  }

  /* ── scroll-linked universe transitions ─────────────────────────────── */
  const contentEl = document.getElementById('content-area');
  const navEl     = document.querySelector('header.nav');

  /* Token endpoints per universe — canonical from Figma modes (file 8JMA60B81nVHQKIsNRIWS7).
     RGB arrays + scalars; fonts snap (can't interpolate), colors/radius/bw lerp. */
  const THEMES = {
    main: {
      paper:[243,241,234], paper2:[236,233,223], ink:[22,22,15], muted:[79,78,68], faint:[120,118,106],
      accent:[226,52,29], accentInk:[168,35,9], lineRgb:[20,20,12], lineStrong:[22,22,15], radius:8, bw:2, pad:56,
      display:"'Bricolage Grotesque','Host Grotesk',system-ui,sans-serif", headline:"'Bebas Neue','Bricolage Grotesque',system-ui,sans-serif", sans:"'Host Grotesk',system-ui,sans-serif",
    },
    ruralvia: {
      paper:[239,234,198], paper2:[231,224,180], ink:[28,58,43], muted:[46,125,82], faint:[111,138,116],
      accent:[46,125,82], accentInk:[30,92,58], lineRgb:[28,58,43], lineStrong:[28,58,43], radius:24, bw:2, pad:64,
      display:"'Fraunces',Georgia,serif", headline:"'Fraunces',Georgia,serif", sans:"'Hanken Grotesk',system-ui,sans-serif",
    },
    flame: {
      paper:[236,233,223], paper2:[227,222,208], ink:[22,22,15], muted:[79,78,68], faint:[140,137,125],
      accent:[226,52,29], accentInk:[168,35,9], lineRgb:[20,20,12], lineStrong:[22,22,15], radius:0, bw:4, pad:64,
      display:"'Archivo Black',system-ui,sans-serif", headline:"'Archivo',system-ui,sans-serif", sans:"'Inter',system-ui,sans-serif",
    },
    erneszt: {
      paper:[26,18,9], paper2:[36,26,14], ink:[239,234,198], muted:[217,194,115], faint:[154,138,88],
      accent:[201,162,75], accentInk:[217,194,115], lineRgb:[236,234,198], lineStrong:[201,162,75], radius:4, bw:2, pad:72,
      display:"'Playfair Display',Georgia,serif", headline:"'Playfair Display',Georgia,serif", sans:"'Lora',Georgia,serif",
    },
  };

  const SEGMENTS = [
    { triggerId:'rv-trigger',      slateId:'rv-slate',      from:'main',     to:'ruralvia' },
    { triggerId:'flame-trigger',   slateId:'flame-slate',   from:'ruralvia', to:'flame'    },
    { triggerId:'erneszt-trigger', slateId:'erneszt-slate', from:'flame',    to:'erneszt'  },
  ].map((s) => {
    const slateEl = document.getElementById(s.slateId);
    return {
      ...s,
      triggerEl: document.getElementById(s.triggerId),
      slateEl,
      readoutDd: slateEl ? slateEl.querySelectorAll('.slate-readout dd') : [],
    };
  }).filter((s) => s.triggerEl && s.slateEl);

  /* Position slates flush below nav so the frame stays visible */
  if (navEl) SEGMENTS.forEach((s) => { s.slateEl.style.top = `${navEl.offsetHeight}px`; });

  const lerp     = (a, b, t) => a + (b - a) * t;
  const lerpRgb  = (a, b, t) => `rgb(${Math.round(lerp(a[0],b[0],t))},${Math.round(lerp(a[1],b[1],t))},${Math.round(lerp(a[2],b[2],t))})`;
  const toHex    = (r, g, b) => '#' + [r,g,b].map((v) => Math.round(v).toString(16).padStart(2,'0')).join('');
  const easeInOut = (t) => (t < 0.5 ? 2*t*t : -1+(4-2*t)*t);
  const clamp    = (v) => Math.max(0, Math.min(1, v));

  /* Bell-curve: slate visible 0.25 → 0.75, opaque peak at 0.5 (masks the muddy mid-morph) */
  function slateAlpha(p) {
    if (p <= 0.25 || p >= 0.75) return 0;
    return Math.sin(((p - 0.25) / 0.5) * Math.PI);
  }

  function progress(el) {
    const rect = el.getBoundingClientRect();
    const vh   = window.innerHeight;
    return clamp((vh - rect.top) / (rect.height + vh));
  }

  function applyTokens(fromKey, toKey, t) {
    if (!contentEl) return;
    const A = THEMES[fromKey], B = THEMES[toKey], el = contentEl;
    el.style.setProperty('--paper',       lerpRgb(A.paper,      B.paper,      t));
    el.style.setProperty('--paper-2',     lerpRgb(A.paper2,     B.paper2,     t));
    el.style.setProperty('--ink',         lerpRgb(A.ink,        B.ink,        t));
    el.style.setProperty('--accent',      lerpRgb(A.accent,     B.accent,     t));
    el.style.setProperty('--accent-ink',  lerpRgb(A.accentInk,  B.accentInk,  t));
    el.style.setProperty('--muted',       lerpRgb(A.muted,      B.muted,      t));
    el.style.setProperty('--faint',       lerpRgb(A.faint,      B.faint,      t));
    el.style.setProperty('--line',
      `rgba(${A.lineRgb.map((v,i) => Math.round(lerp(v, B.lineRgb[i], t))).join(',')},0.14)`);
    el.style.setProperty('--line-strong', lerpRgb(A.lineStrong, B.lineStrong, t));
    el.style.setProperty('--radius', `${Math.round(lerp(A.radius, B.radius, t))}px`);
    el.style.setProperty('--bw',     `${lerp(A.bw, B.bw, t).toFixed(1)}px`);
    el.style.setProperty('--pad',    `${Math.round(lerp(A.pad,    B.pad,    t))}px`);

    /* Fonts can't interpolate — snap at the midpoint, hidden behind the flood slate */
    const F = THEMES[t < 0.5 ? fromKey : toKey];
    el.style.setProperty('--display',  F.display);
    el.style.setProperty('--headline', F.headline);
    el.style.setProperty('--sans',     F.sans);
  }

  function updateReadout(seg, t) {
    const A = THEMES[seg.from], B = THEMES[seg.to], dd = seg.readoutDd;
    if (dd.length < 4) return;
    const paper = A.paper.map((v,i) => lerp(v, B.paper[i], t));
    const ink   = A.ink.map((v,i)   => lerp(v, B.ink[i],   t));
    dd[0].textContent = toHex(paper[0], paper[1], paper[2]);
    dd[1].textContent = toHex(ink[0], ink[1], ink[2]);
    dd[2].textContent = `${Math.round(lerp(A.radius, B.radius, t))}px`;
    dd[3].textContent = `${Math.round(lerp(A.pad,    B.pad,    t))}px`;
  }

  function update() {
    const ps = SEGMENTS.map((s) => progress(s.triggerEl));
    SEGMENTS.forEach((s, i) => { s.slateEl.style.opacity = String(slateAlpha(ps[i])); });

    /* Walk segments in order to find the single applied theme state */
    let fromKey = SEGMENTS[0].from, toKey = SEGMENTS[0].from, t = 0;
    for (let i = 0; i < SEGMENTS.length; i++) {
      const p = ps[i];
      if (p >= 1) { fromKey = toKey = SEGMENTS[i].to; t = 0; continue; }
      if (p <= 0) { fromKey = toKey = SEGMENTS[i].from; t = 0; break; }
      fromKey = SEGMENTS[i].from; toKey = SEGMENTS[i].to; t = easeInOut(p);
      updateReadout(SEGMENTS[i], t);
      break;
    }
    applyTokens(fromKey, toKey, t);
  }

  if (!reduce && SEGMENTS.length) {
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  } else if (reduce) {
    /* Reduced motion: snap each universe theme as its showcase enters */
    const showcases = document.querySelectorAll('[data-universe]');
    const themeObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && contentEl) {
          contentEl.setAttribute('data-theme', e.target.getAttribute('data-universe'));
        }
      });
    }, { threshold: 0.4 });
    showcases.forEach((n) => themeObs.observe(n));
  }
</script>
