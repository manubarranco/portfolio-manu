---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const channels = [
  { k: 'LinkedIn', v: '/in/manubarranco', href: 'https://linkedin.com/in/manubarranco' },
  { k: 'Email', v: 'mbarranco@gmail.com', href: 'mailto:mbarranco@gmail.com' },
];
---

<Base title="Contact — Manu Barranco">
  <Nav />
  <main class="contact wrap">
    <p class="eyebrow">Say hello</p>
    <h1>Let's collaborate.</h1>
    <p class="lead">
      Tell me about the system you're trying to build, or the decision you're stuck on.
      I read everything.
    </p>
    <ul class="channels">
      {channels.map((c) => (
        <li>
          <a href={c.href}>
            <span class="k mono">{c.k}</span>
            <span class="v">{c.v} ↗</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Base>

<style>
  .contact { padding-top: 72px; }
  .contact h1 { font-family: var(--display); font-weight: 800; font-size: clamp(48px, 11vw, 108px); line-height: 0.94; letter-spacing: -0.02em; margin: 18px 0; }
  .lead { font-weight: 500; font-size: 23px; line-height: 1.36; letter-spacing: -0.015em; max-width: 30ch; }
  .channels { list-style: none; margin-top: 56px; border-top: 1.5px solid var(--line-strong); }
  .channels li { border-bottom: 1.5px solid var(--line); }
  .channels a { display: flex; justify-content: space-between; align-items: baseline; padding: 24px 0; transition: padding 0.15s, color 0.15s; }
  .channels a:hover { padding-left: 12px; color: var(--accent); }
  .channels .k { color: var(--accent-ink); text-transform: uppercase; font-size: 12px; }
  .channels .v { font-size: clamp(22px, 4vw, 34px); font-weight: 500; letter-spacing: -0.02em; }
</style>
