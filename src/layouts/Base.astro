---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Manu Barranco · Product design leader',
  description = 'I define the system and make the decisions that set the direction. Then I lead the execution and adoption to make it real. Design systems and AI-native products.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Archivo+Black&family=Bebas+Neue&family=Bigshot+One&family=Bricolage+Grotesque:opsz,wght@12..96,600..800&family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Hanken+Grotesk:wght@400..700&family=Host+Grotesk:ital,wght@0,400..700;1,400..700&family=Inter:wght@400..700&family=Kode+Mono:wght@400..700&family=Lora:ital,wght@0,400..700;1,400..600&family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Space+Mono:wght@400;700&family=Stack+Sans+Headline:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
