---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const items = await getCollection('work');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const d = item.data;
---

<Base title={`${d.title} · Manu Barranco`} description={d.summary}>
  <Nav />
  <article class={`cs${d.aiNative ? ' is-ai' : ''}`}>
    <header class="cs-head wrap">
      <p class="eyebrow">{d.category}</p>
      <h1>{d.title}</h1>
      <p class="summary">{d.summary}</p>
    </header>

    <div class="cs-body wrap">
      <aside class="meta" aria-label="Project details">
        <div><span class="k mono">Client</span><span class="v">{d.client}</span></div>
        <div><span class="k mono">Year</span><span class="v">{d.years}</span></div>
        <div><span class="k mono">Timeframe</span><span class="v">{d.timeframe}</span></div>
        <div><span class="k mono">Category</span><span class="v">{d.category}</span></div>
      </aside>
      <div class="prose">
        <Content />
      </div>
    </div>

    <nav class="cs-foot wrap" aria-label="Case study">
      <a href="/#work">← All work</a>
      <a href="/contact">Get in touch ↗</a>
    </nav>
  </article>
  <Footer />
</Base>

<style>
  .cs-head { padding-top: 64px; }
  .cs-head .eyebrow { color: var(--accent-ink); }
  .cs-head h1 { font-family: var(--display); font-weight: 800; font-size: clamp(48px, 10vw, 104px); line-height: 0.94; letter-spacing: -0.02em; margin: 18px 0; }
  .cs-head .summary { font-weight: 500; font-size: clamp(20px, 2.6vw, 28px); line-height: 1.32; letter-spacing: -0.015em; max-width: 24ch; }

  .cs-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 64px;
    margin-top: 56px;
    border-top: 1.5px solid var(--line-strong);
    padding-top: 40px;
  }
  .meta { display: flex; flex-direction: column; gap: 22px; position: sticky; top: 32px; align-self: start; }
  .meta .k { display: block; color: var(--accent-ink); text-transform: uppercase; font-size: 11px; letter-spacing: 0.03em; margin-bottom: 6px; }
  .meta .v { font-size: 15px; }

  .cs-foot { display: flex; justify-content: space-between; margin-top: 80px; padding-top: 28px; border-top: 1.5px solid var(--line); font-family: var(--mono); font-size: 13px; }
  .cs-foot a { transition: color 0.12s, background 0.12s, box-shadow 0.12s; }
  .cs-foot a:hover { background: var(--accent); color: var(--paper); box-shadow: 0 0 0 0.12em var(--accent); }

  /* prose */
  .prose { max-width: 70ch; font-size: 18px; line-height: 1.7; }
  .prose :global(h2) { font-family: var(--headline); font-weight: 400; font-size: clamp(34px, 4.4vw, 50px); line-height: 1.0; letter-spacing: -0.02em; margin: 1.8em 0 0.7em; padding-bottom: 0.1em; border-bottom: 2px solid var(--accent); }
  .prose :global(h3) { font-family: var(--headline); font-weight: 400; font-size: clamp(26px, 3vw, 32px); line-height: 1.0; letter-spacing: -0.02em; margin: 1.7em 0 0.3em; }
  .prose :global(h2:first-child), .prose :global(h3:first-child) { margin-top: 0; }
  .prose :global(p) { margin: 0 0 1.1em; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(em) { font-style: italic; }
  .prose :global(a) { color: var(--accent-ink); text-decoration: underline; text-underline-offset: 3px; transition: color 0.12s, background 0.12s, box-shadow 0.12s; }
  .prose :global(a:hover) { background: var(--accent); color: var(--paper); text-decoration-color: transparent; box-shadow: 0 0 0 0.08em var(--accent); }
  .prose :global(ul) { margin: 0 0 1.2em; padding-left: 1.1em; }
  .prose :global(li) { margin: 0.35em 0; }
  .prose :global(blockquote) {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 1.5em 0;
    padding-left: 22px;
    border-left: 3px solid var(--accent);
    border-radius: 0;
  }
  .prose :global(blockquote p) { margin: 0; }

  .prose :global(.metrics) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin: 2em 0;
  }
  .prose :global(.metric) { background: var(--paper); padding: 22px 18px; display: flex; flex-direction: column; gap: 6px; }
  .prose :global(.metric .num) { font-family: var(--headline); font-weight: 400; font-size: clamp(36px, 4.6vw, 52px); line-height: 0.95; letter-spacing: -0.02em; color: var(--accent); }
  .prose :global(.metric .lbl) { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.03em; color: var(--muted); }

  .prose :global(.video) { position: relative; aspect-ratio: 16 / 9; margin: 2em 0; border: 1.5px solid var(--line-strong); background: var(--ink); }
  .prose :global(.video iframe) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  .prose :global(.callout) {
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.5;
    border: 1.5px solid var(--line-strong);
    padding: 16px 20px;
    margin: 1.8em 0;
  }
  .prose :global(.callout strong) { color: var(--accent-ink); font-weight: 700; }

  .prose :global(figure.shot) { margin: 2.2em 0; }
  .prose :global(figure.shot img) { display: block; width: 100%; height: auto; border: 1.5px solid var(--line); background: var(--paper-2); }
  .prose :global(figure.shot figcaption) { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.03em; color: var(--faint); margin-top: 10px; }
  .prose :global(.shot-row) { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 2.2em 0; }
  .prose :global(.shot-row figure.shot) { margin: 0; }

  @media (max-width: 860px) {
    .cs-body { grid-template-columns: 1fr; gap: 32px; }
    .meta { position: static; flex-direction: row; flex-wrap: wrap; gap: 24px 40px; }
    .prose :global(.metrics) { grid-template-columns: repeat(2, 1fr); }
  }
</style>
