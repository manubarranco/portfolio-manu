<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── reveal on scroll */
  const revealEls = document.querySelectorAll('[data-reveal]');
  if (revealEls.length && !reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      },
      { rootMargin: '0px 0px -12% 0px' },
    );
    revealEls.forEach((n) => io.observe(n));
  } else {
    revealEls.forEach((n) => n.classList.add('in'));
  }

  /* ── shared: header height → CSS var, consumed by the cover reveal (px math) and by
     the fixed cartelas' `top` ── */
  function measureHeaderHeight() {
    const h = document.querySelector('header.nav').offsetHeight;
    document.documentElement.style.setProperty('--header-h', `${h}px`);
    return h;
  }
  measureHeaderHeight();
  window.addEventListener('resize', measureHeaderHeight, { passive: true });

  /* ── cover → header reveal: the cover scrolls up under the fixed header bar;
     the header content rises from the line as the name disappears (same proportion) ── */
  const navInner  = document.querySelector('header.nav .nav-inner');
  const coverEl   = document.querySelector('.cover');
  const coverName = document.querySelector('.cover-name');
  const coverFoot = document.querySelector('.cover-foot');

  if (navInner && coverEl && coverName && coverFoot && !reduce) {
    let barH = 0, revealStart = 0, revealSpan = 1;
    function measureReveal() {
      barH = measureHeaderHeight();
      coverEl.style.height = (window.innerHeight - barH) + 'px'; /* fill the viewport minus the sticky header so name + role always fit */
      const y = window.scrollY;
      const nameTop = coverName.getBoundingClientRect().top + y;
      const nameBot = coverName.getBoundingClientRect().bottom + y;
      const leadIn  = (nameBot - nameTop) * 0.55; /* start before the name visually touches the line, so the header isn't slow to appear */
      revealStart = (nameTop - barH) - leadIn;
      revealSpan  = Math.max(1, (nameBot - barH) - revealStart); /* completes once "Barranco" has passed the line — well before the #hero anchor lands, so clicking the brand leaves no residual header motion */
    }
    function reveal() {
      let p = (window.scrollY - revealStart) / revealSpan;
      p = Math.max(0, Math.min(1, p));
      /* header content tucked below the line at p=0, risen into place in the same proportion the cover disappears */
      navInner.style.transform = `translateY(${((1 - p) * barH).toFixed(1)}px)`;
    }
    measureReveal();
    reveal();
    document.documentElement.classList.remove('morph-js');
    window.addEventListener('scroll', reveal, { passive: true });
    window.addEventListener('resize', () => { measureReveal(); reveal(); }, { passive: true });
  } else if (reduce) {
    if (coverEl) coverEl.style.display = 'none';
    document.documentElement.classList.remove('morph-js');
  }

  /* ── cartelas: fixed backdrops shown/hidden by scroll position, chips ticking within
     the active one. Surfaces do the actual covering (they're normal-flow, opaque, higher
     z-index) — this only decides WHICH cartela is exposed and drives its chips. ── */
  function clamp(v) { return Math.max(0, Math.min(1, v)); }
  function lerp(a, b, t) { return a + (b - a) * t; }
  function toHex(r, g, b) {
    return '#' + [r, g, b].map((v) => Math.round(v).toString(16).padStart(2, '0').toUpperCase()).join('');
  }

  const cartelaGaps = document.querySelectorAll('.cartela-gap');
  const cartelaEls  = {};
  document.querySelectorAll('.cartela[data-theme]').forEach((el) => { cartelaEls[el.dataset.theme] = el; });

  /* Give colour chips a live swatch: wrap the value in a row and prepend a square whose fill the
     update loop keeps in sync with the ticking hex. Seed it with the chip's resting value so it
     shows the right colour before any scroll. Numeric chips (radius/border/space) get nothing. */
  /* Astro's scoped styles only match elements carrying its data-astro-cid-* attribute, which
     elements created via createElement never get — copy it from the chip itself so the swatch
     and row actually receive the .chip-swatch / .chip-value-row rules instead of collapsing. */
  const astroCidAttr = document.querySelector('.chip')?.getAttributeNames().find((n) => n.startsWith('data-astro-cid'));
  document.querySelectorAll('.chip[data-from-rgb]').forEach((chip) => {
    const valueEl = chip.querySelector('.chip-value');
    if (!valueEl) return;
    const row = document.createElement('span');
    row.className = 'chip-value-row';
    const swatch = document.createElement('span');
    swatch.className = 'chip-swatch';
    swatch.style.background = valueEl.textContent.trim();
    if (astroCidAttr) {
      row.setAttribute(astroCidAttr, '');
      swatch.setAttribute(astroCidAttr, '');
    }
    valueEl.parentNode.insertBefore(row, valueEl);
    row.append(swatch, valueEl);
  });

  function updateCartelas() {
    const headerH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 0;
    const vh = window.innerHeight;
    let activeKey = null;
    let activeGap = null;

    cartelaGaps.forEach((gap) => {
      const rect = gap.getBoundingClientRect();
      /* Active for the WHOLE time this gap overlaps the visible area below the header —
         from the instant its top edge (the departing surface's bottom edge) enters from
         the viewport bottom, through the full-screen dwell, until the next surface has
         covered it past the header line. The fixed cartela behind then shows through the
         transparent gap and is progressively revealed by the departing surface's rising
         edge — no sudden pop. Later gaps win the tie so an incoming reveal takes over. */
      if (rect.top < vh && rect.bottom > headerH) {
        activeKey = gap.dataset.cartela;
        activeGap = gap;
      }
    });

    Object.entries(cartelaEls).forEach(([key, el]) => {
      el.classList.toggle('is-active', key === activeKey);
    });

    if (!activeKey || reduce || !activeGap) return;

    const rect    = activeGap.getBoundingClientRect();
    const docTop  = rect.top + window.scrollY;
    const docBottom = docTop + rect.height;
    /* entryP: 0 when the gap's top is at the viewport bottom (reveal just starting), 1 once
       it reaches the header line (departing surface fully gone, cartela fully exposed). While
       entryP < 1, anything above the departing surface's still-covering edge is invisible —
       chips must not rise past that line early, or they skip straight from "hidden behind the
       departing surface" to "scrolled off past the top" without ever passing through view. */
    const entryP  = clamp((vh - rect.top) / (vh - headerH));
    /* pTotal: 0→1 across the WHOLE active window (reveal + the dwell after it, until the next
       surface starts covering) — this is what each chip's own journey and value-tick run on. */
    const pTotal  = clamp((window.scrollY - (docTop - vh)) / ((docBottom - headerH) - (docTop - vh)));
    /* How far above/below the cartela's center the departing surface's bottom edge (the
       reveal boundary) currently sits, in the same offset units as --chip-y. */
    const boundaryOffset = (vh - headerH) * (0.5 - entryP);

    const cartela = cartelaEls[activeKey];
    cartela.querySelectorAll('.chip').forEach((chip) => {
      /* Each chip's own exponent bends its timing curve — front-loaded vs back-loaded — and
         its own start/end range means no two chips share a position or a speed: scattered and
         staggered, like Matrix rain, rather than a synchronized wave that lines up and
         collides. localP runs on pTotal (the full window), not just the reveal, so there's
         room for the chip to keep climbing and exit during the dwell after it's fully shown. */
      const exponent = parseFloat(chip.dataset.depth) || 1;
      const localP = Math.pow(pTotal, exponent);
      /* start/end are fractions of viewport height, not fixed px, so the exit point always
         clears the cartela's visible half regardless of screen size — chips fully leave
         through the top rather than parking just inside the edge. */
      const startY = (parseFloat(chip.dataset.startY) || 0.3) * vh;
      const endY   = (parseFloat(chip.dataset.endY) || -0.6) * vh;
      const rawOffset = lerp(startY, endY, localP);
      /* While the departing surface is still covering part of the screen, hold the chip at
         the reveal boundary if its own curve would otherwise put it above it (hidden); once
         entryP reaches 1 the clamp lifts entirely and the chip is free to climb the rest of
         the way out. */
      const chipY = entryP < 1 ? Math.max(rawOffset, boundaryOffset) : rawOffset;
      chip.style.setProperty('--chip-y', `${chipY.toFixed(1)}px`);

      const valueEl = chip.querySelector('.chip-value');
      if (!valueEl) return;
      if (chip.dataset.fromRgb) {
        const from = chip.dataset.fromRgb.split(',').map(Number);
        const to = chip.dataset.toRgb.split(',').map(Number);
        const hex = toHex(
          lerp(from[0], to[0], localP),
          lerp(from[1], to[1], localP),
          lerp(from[2], to[2], localP),
        );
        valueEl.textContent = hex;
        const swatch = chip.querySelector('.chip-swatch');
        if (swatch) swatch.style.background = hex;
      } else if (chip.dataset.fromNum) {
        const from = parseFloat(chip.dataset.fromNum), to = parseFloat(chip.dataset.toNum);
        valueEl.textContent = `${Math.round(lerp(from, to, localP))}${chip.dataset.unit || ''}`;
      }
    });
  }
  if (cartelaGaps.length) {
    window.addEventListener('scroll', updateCartelas, { passive: true });
    window.addEventListener('resize', updateCartelas, { passive: true });
    updateCartelas();
  }
</script>
