  /* ── cartela (floor 0 title card): fixed backdrop, always same screen position, never
     scrolls. JS toggles .is-active (hard cut, no fade) based on which .cartela-gap the
     scroll position is currently inside. ── */
  .cartela {
    position: fixed;
    top: var(--header-h, 0px);
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    overflow: hidden;
    background: var(--cartela-bg);
    visibility: hidden;
    pointer-events: none;
  }
  .cartela.is-active { visibility: visible; }

  /* Cartelas invert their universe: bold saturated backdrop + light text (the old flood-slate
     palette). data-theme still governs the display FONT per universe; only the colors flip. */
  .cartela[data-theme="ruralvia"] {
    --cartela-bg: #00804E;
    --cartela-title: #ECD643;
  }
  /* photo sits on the flat --cartela-bg as its own layer (not baked into .cartela's
     background) so it can carry its own blend mode + opacity, matching the Figma treatment
     (hard-light, 75%) instead of a flat scrim. */
  .cartela[data-theme="ruralvia"]::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('/cartelas/ruralvia-wheat.jpg');
    background-size: cover;
    background-position: center;
    mix-blend-mode: hard-light;
    opacity: 0.75;
  }
  .cartela[data-theme="flame"] {
    --cartela-bg: #F61000;
    --cartela-title: #FFFFFF;
  }
  .cartela[data-theme="flame"]::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('/cartelas/flame-fire.jpg');
    background-size: cover;
    background-position: center;
    mix-blend-mode: hard-light;
  }
  .cartela[data-theme="erneszt"] {
    --cartela-bg: #E95900;
    --cartela-title: #D0A136;
